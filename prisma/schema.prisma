// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Development uses SQLite.
// Later when deploying to Railway, we will change this to PostgreSQL.
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model DeliverySettings {
  id                     Int      @id @default(autoincrement())

  shop                   String   @unique

  enabled                Boolean  @default(true)

  minimumPreparationDays Int      @default(1)

  enableMorning          Boolean  @default(true)
  enableAfternoon        Boolean  @default(true)
  enableEvening          Boolean  @default(false)

  disableSunday          Boolean  @default(true)

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}